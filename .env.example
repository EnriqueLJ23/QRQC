# Copia este archivo a .env (local) o cárgalo como stack .env en Portainer.
# Nunca commitees el .env real: ya está en .gitignore.

# Postgres. Si el servidor de Postgres corre en el MISMO host Docker que este
# contenedor, "localhost" NO funciona dentro del contenedor: usa
# host.docker.internal (ya mapeado en docker-compose.yml) o la IP LAN del host.
DATABASE_URL=postgresql://usuario:password@host.docker.internal:5432/qrqc

# Sesión (cookie firmada) — genera un valor largo y aleatorio, distinto por ambiente.
SESSION_SECRET=

# Microsoft Entra ID (MSAL)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
# Debe coincidir EXACTO con el redirect URI registrado en Entra ID para este ambiente.
MICROSOFT_REDIRECT_URI=https://qrqc.tudominio.com/auth/callback

# Correo saliente vía Microsoft Graph (client credentials, requiere Mail.Send con admin consent)
MAIL_SENDER=

# URL pública de la app (sin slash final) — se usa en los enlaces de los correos de recordatorio.
BASE_URL=https://qrqc.tudominio.com

# Puerto interno del contenedor (coincide con EXPOSE del Dockerfile y docker-compose.yml)
PORT=3000
